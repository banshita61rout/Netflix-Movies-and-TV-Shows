import pandas as pd
netflix_df=pd.read_csv("netflix_titles.csv")
netflix_df.head(5)



netflix_df.shape


netflix_df.columns


new_netflix=netflix_df.copy()


#Changing Column Names
new_netflix.rename(columns={
    "title":"Title",
    "director":"Director",
    "cast":"Cast",
    "country":"Country",
    "rating":"Rating",
    "release_year":"Release_Year",
    "duration":"Duration",
    "description":"Description",
    "type":"Type",
    "show_id":"Id",
    "date_added": "Date",
    "listed_in": "Genre"
}, inplace=True)

new_netflix


netflix_df.isnull().sum()


new_netflix.columns


#cleaing data - Replacing Missing val

new_netflix["Director"] = new_netflix["Director"].fillna("Unknown")
new_netflix["Cast"] = new_netflix["Cast"].fillna("Unknown")
new_netflix["Country"] = new_netflix["Country"].fillna("Not Specified")
new_netflix["Date"] = new_netflix["Date"].fillna("Not Available")
new_netflix["Rating"] = new_netflix["Rating"].fillna("Not Rated")
new_netflix["Duration"] = new_netflix["Duration"].fillna("Not Available")
new_netflix


new_netflix.isnull().sum()





#Duplication check
new_netflix.duplicated().sum()


new_netflix.columns





new_netflix["Date"] = pd.to_datetime(new_netflix['Date'])
new_netflix['Date'] = new_netflix['Date'].dt.day
new_netflix['year_added'] = new_netflix['date_added'].dt.year
new_netflix['month_added']=new_netflix['date_added'].dt.month
new_netflix['year_added'].astype(int);
new_netflix['day_added'].astype(int);



